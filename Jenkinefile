// Hello
pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Deepandeeps29/Sample_API.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install -g newman'
                bat 'npm install -g newman-reporter-htmlextra'
            }
        }

        stage('Run API Tests') {
            steps {
                bat '''
                if not exist reports mkdir reports

                newman run "C:/Users/Deepan Vinayagam/Desktop/Asset_Management/Practice/API_Automation/Sample/Collection/API_Testing.postman_collection.json" ^
                -e "C:/Users/Deepan Vinayagam/Desktop/Asset_Management/Practice/API_Automation/Sample/Environment/QA.postman_environment.json" ^
                -r cli,htmlextra,junit ^
                --reporter-htmlextra-export "C:/Users/Deepan Vinayagam/Desktop/Asset_Management/Practice/API_Automation/Sample/Reports/API_Report.html" ^
                --reporter-junit-export "C:/Users/Deepan Vinayagam/Desktop/Asset_Management/Practice/API_Automation/Sample/Reports/API_Report.xml"
                '''
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true,
                  testResults: 'reports/API_Report.xml'

            emailext(
                subject: "API Automation - ${env.BUILD_NUMBER}",
                body: "Execution completed",
                to: "deepanvinayagam2912@gmail.com",
                attachmentsPattern: "reports/API_Report.html"
            )
        }
    }
}
